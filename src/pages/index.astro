---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { siteConfig } from '@/config/site';
import { getAllTags, getPosts } from '@/utils/posts';

const posts = await getPosts();
const tags = getAllTags(posts);
const latestPosts = posts.slice(0, 8);
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteConfig.title,
  description: siteConfig.description,
  url: siteConfig.url,
  inLanguage: siteConfig.locale,
  publisher: {
    '@type': 'Person',
    name: siteConfig.author,
    url: siteConfig.url,
    jobTitle: '全栈工程师，主前端，AI 智能体开发者',
  },
};
---
<BaseLayout current="home">
  <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
  <section class="site-shell hero">
    <div class="hero-card">
      <p class="kicker">Personal Journal</p>
      <h1>写点技术，也写点生活里反复想起的事。</h1>
      <p>这里有前端和全栈实践，也有 AI Agent、读书笔记、月度复盘，以及一些关于效率、家庭和长期学习的记录。</p>
      <div class="hero-actions">
        <a class="button primary" href="/archives/">浏览全部文章</a>
        <a class="button" href="/tags/">按主题阅读</a>
      </div>
    </div>
    <aside class="profile-card" aria-label="作者简介">
      <div>
        <img class="avatar" src="/avatar.png" alt="常敬礼头像" />
        <h2>常敬礼</h2>
        <p>工程师，前端写得多一些，也在做全栈和 AI Agent。这个博客用来放实践、复盘，以及那些暂时还不想忘掉的想法。</p>
      </div>
      <div class="stats">
        <div class="stat"><strong>{posts.length}</strong><span>篇文章</span></div>
        <div class="stat"><strong>{tags.length}</strong><span>个标签</span></div>
      </div>
    </aside>
  </section>

  <section class="site-shell">
    <div class="section-head">
      <div>
        <h2>最新文章</h2>
        <p>从最近的复盘和思考开始。</p>
      </div>
      <a class="button" href="/archives/">查看归档</a>
    </div>
    <div class="post-grid">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
