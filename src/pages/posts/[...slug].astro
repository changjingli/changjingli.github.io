---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleGrowth from '@/components/ArticleGrowth.astro';
import { absoluteUrl, siteConfig } from '@/config/site';
import {
  formatDate,
  getAdjacentPosts,
  getExcerpt,
  getPostPath,
  getPosts,
  getPostSlug,
  getReadingTime,
  getRelatedPosts,
} from '@/utils/posts';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({ params: { slug: getPostSlug(post) }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const description = post.data.description ?? getExcerpt(post.body, 150);
const canonicalPath = getPostPath(post);
const posts = await getPosts();
const { newerPost, olderPost } = getAdjacentPosts(posts, post);
const adjacentSlugs = [newerPost, olderPost].flatMap((entry) => entry ? [getPostSlug(entry)] : []);
const relatedPosts = getRelatedPosts(posts, post, 3, adjacentSlugs);
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description,
  datePublished: post.data.date.toISOString(),
  dateModified: (post.data.updated ?? post.data.date).toISOString(),
  url: absoluteUrl(canonicalPath),
  mainEntityOfPage: absoluteUrl(canonicalPath),
  inLanguage: siteConfig.locale,
  author: {
    '@type': 'Person',
    name: siteConfig.author,
    url: siteConfig.url,
  },
  publisher: {
    '@type': 'Person',
    name: siteConfig.author,
    url: siteConfig.url,
  },
  keywords: post.data.tags,
};
---
<BaseLayout title={post.data.title} description={description} type="article" publishedTime={post.data.date} modifiedTime={post.data.updated ?? post.data.date}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <article
    class="article-shell"
    data-article
    data-article-title={post.data.title}
    data-article-slug={getPostSlug(post)}
  >
    <header class="article-header">
      <p class="kicker">Article</p>
      <h1>{post.data.title}</h1>
      <div class="article-meta">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        <span>·</span>
        <span>{getReadingTime(post.body)} 分钟阅读</span>
      </div>
      {post.data.tags.length > 0 && (
        <div class="tag-row" style="margin-top: 18px;">
          {post.data.tags.map((tag) => <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>)}
        </div>
      )}
    </header>
    <div class="prose heti" data-article-content>
      <Content />
    </div>
    <ArticleGrowth
      title={post.data.title}
      canonicalUrl={absoluteUrl(canonicalPath)}
      relatedPosts={relatedPosts}
      newerPost={newerPost}
      olderPost={olderPost}
    />
  </article>
</BaseLayout>
