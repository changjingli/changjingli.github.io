---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPosts, formatDate, getPostSlug, getReadingTime } from '@/utils/posts';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({ params: { slug: getPostSlug(post) }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---
<BaseLayout title={post.data.title} description={post.data.description ?? post.data.title}>
  <article class="article-shell">
    <header class="article-header">
      <p class="kicker">Article</p>
      <h1>{post.data.title}</h1>
      <div class="article-meta">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        <span>·</span>
        <span>{getReadingTime(post.body)} 分钟阅读</span>
      </div>
      {post.data.tags.length > 0 && (
        <div class="tag-row" style="margin-top: 18px;">
          {post.data.tags.map((tag) => <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>)}
        </div>
      )}
    </header>
    <div class="prose heti">
      <Content />
    </div>
  </article>
</BaseLayout>
