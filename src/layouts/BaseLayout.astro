---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import GoogleAnalytics from '@/components/GoogleAnalytics.astro';
import { absoluteUrl, siteConfig } from '@/config/site';

interface Props {
  title?: string;
  description?: string;
  current?: 'home' | 'archives' | 'tags' | 'about';
  type?: 'website' | 'article';
  image?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  current,
  type = 'website',
  image = '/og-default.svg',
  publishedTime,
  modifiedTime,
} = Astro.props;
const pageTitle = title === siteConfig.title ? title : `${title} · ${siteConfig.title}`;
const canonicalUrl = absoluteUrl(Astro.url.pathname);
const imageUrl = absoluteUrl(image);
---
<!doctype html>
<html lang={siteConfig.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.author} />
    <meta name="keywords" content={siteConfig.keywords.join(',')} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.title} RSS`} href={absoluteUrl('/rss.xml')} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content="zh_CN" />
    {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <link rel="icon" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <ClientRouter />
    <GoogleAnalytics />
  </head>
  <body>
    <header class="site-header">
      <div class="site-shell nav">
        <a class="brand" href="/" aria-label="敬礼的唠叨首页">
          <span class="brand-mark">常</span>
          <span class="brand-text">
            <span class="brand-title">敬礼的唠叨</span>
            <span class="brand-subtitle">Stay Hungry, Stay Foolish.</span>
          </span>
        </a>
        <nav class="nav-links" aria-label="主导航">
          <a href="/" aria-current={current === 'home' ? 'page' : undefined}>首页</a>
          <a href="/archives/" aria-current={current === 'archives' ? 'page' : undefined}>归档</a>
          <a href="/tags/" aria-current={current === 'tags' ? 'page' : undefined}>标签</a>
          <a href="/about/" aria-current={current === 'about' ? 'page' : undefined}>关于</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-shell">
        <span>© {new Date().getFullYear()} 常敬礼</span>
        <span>Built with Astro · 保持好奇，保持进步</span>
      </div>
    </footer>
  </body>
</html>
