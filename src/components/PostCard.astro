---
import type { BlogPost } from '@/utils/posts';
import { formatDate, formatDay, formatYearMonth, getExcerpt, getPostPath, getReadingTime } from '@/utils/posts';

interface Props {
  post: BlogPost;
  growthEvent?: string;
  variant?: 'default' | 'compact';
}

const { post, growthEvent, variant = 'default' } = Astro.props;
const date = post.data.date;
const day = formatDay(date);
const month = formatYearMonth(date);
---
<a
  class:list={['post-card', { compact: variant === 'compact' }]}
  href={getPostPath(post)}
  data-growth-event={growthEvent}
  data-growth-label={growthEvent ? post.data.title : undefined}
>
  <time class="post-date" datetime={date.toISOString()}>
    <strong>{day}</strong>
    <span>{month}</span>
  </time>
  <article>
    <h3>{post.data.title}</h3>
    <p>{post.data.description ?? getExcerpt(post.body)}</p>
    <div class="meta-row">
      <span>{formatDate(date)}</span>
      <span>·</span>
      <span>{getReadingTime(post.body)} 分钟阅读</span>
      {post.data.tags.length > 0 && <span>·</span>}
      <span class="tag-row">
        {post.data.tags.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
      </span>
    </div>
  </article>
</a>
