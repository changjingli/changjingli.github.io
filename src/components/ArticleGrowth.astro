---
import type { BlogPost } from '@/utils/posts';
import { formatDate, getExcerpt, getPostPath } from '@/utils/posts';

interface Props {
  title: string;
  canonicalUrl: string;
  relatedPosts: BlogPost[];
  newerPost?: BlogPost;
  olderPost?: BlogPost;
}

const { title, canonicalUrl, relatedPosts, newerPost, olderPost } = Astro.props;
---
<footer class="article-growth">
  <section class="continuation-block" aria-labelledby="continue-reading">
    <div class="section-head compact">
      <div>
        <p class="kicker">Next Read</p>
        <h2 id="continue-reading">继续阅读</h2>
      </div>
      <a class="text-link" href="/archives/" data-growth-event="archive_click">查看全部文章</a>
    </div>
    <div class="related-grid">
      {relatedPosts.map((relatedPost) => (
        <a
          class="related-card"
          href={getPostPath(relatedPost)}
          data-growth-event="related_post_click"
          data-growth-label={relatedPost.data.title}
        >
          <time datetime={relatedPost.data.date.toISOString()}>{formatDate(relatedPost.data.date)}</time>
          <h3>{relatedPost.data.title}</h3>
          <p>{relatedPost.data.description ?? getExcerpt(relatedPost.body, 72)}</p>
        </a>
      ))}
    </div>
  </section>

  {(newerPost || olderPost) && (
    <nav class="article-pagination" aria-label="相邻文章">
      {newerPost ? (
        <a href={getPostPath(newerPost)} data-growth-event="adjacent_post_click" data-growth-label={newerPost.data.title}>
          <span>更新一篇</span>
          <strong>{newerPost.data.title}</strong>
        </a>
      ) : <span />}
      {olderPost && (
        <a class="align-right" href={getPostPath(olderPost)} data-growth-event="adjacent_post_click" data-growth-label={olderPost.data.title}>
          <span>更早一篇</span>
          <strong>{olderPost.data.title}</strong>
        </a>
      )}
    </nav>
  )}

  <section class="retention-card" aria-labelledby="keep-in-touch">
    <div>
      <p class="kicker">Keep In Touch</p>
      <h2 id="keep-in-touch">有新文章时，再见面。</h2>
      <p>通过 RSS 订阅更新，或者把这篇文章分享给可能需要它的人。</p>
    </div>
    <div class="retention-actions">
      <a
        class="button primary"
        href="/rss.xml"
        data-growth-event="subscription_click"
        data-growth-label="article_rss"
      >订阅 RSS</a>
      <button
        class="button"
        type="button"
        data-share-article
        data-share-title={title}
        data-share-url={canonicalUrl}
        data-growth-event="share_click"
      >分享文章</button>
    </div>
    <p class="share-status" data-share-status aria-live="polite"></p>
  </section>
</footer>

<script>
  type ShareWindow = Window & { __articleShareBound?: boolean };
  const shareWindow = window as ShareWindow;

  if (!shareWindow.__articleShareBound) {
    shareWindow.__articleShareBound = true;

    document.addEventListener('click', async (event) => {
      const target = event.target as Element | null;
      const button = target?.closest<HTMLButtonElement>('[data-share-article]');
      if (!button) return;

      const status = button.closest('.retention-card')?.querySelector<HTMLElement>('[data-share-status]');
      const title = button.dataset.shareTitle ?? document.title;
      const url = button.dataset.shareUrl ?? window.location.href;

      try {
        if (navigator.share) {
          await navigator.share({ title, url });
          if (status) status.textContent = '分享面板已打开。';
          return;
        }

        await navigator.clipboard.writeText(url);
        if (status) status.textContent = '文章链接已复制。';
      } catch (error) {
        if ((error as DOMException).name === 'AbortError') return;
        if (status) status.textContent = '暂时无法自动分享，请复制浏览器地址。';
      }
    });
  }
</script>
